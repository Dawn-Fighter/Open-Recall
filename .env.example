GROQ_API_KEY=gsk_your_key_here

# Hindsight local Docker API
HINDSIGHT_BASE_URL=http://localhost:8888
HINDSIGHT_BANK_ID=incident-memory-agent
HINDSIGHT_API_LLM_PROVIDER=groq
HINDSIGHT_API_LLM_API_KEY=${GROQ_API_KEY}
HINDSIGHT_API_LLM_MODEL=openai/gpt-oss-20b
HINDSIGHT_API_CONSOLIDATION_LLM_PROVIDER=none
HINDSIGHT_API_LLM_MAX_CONCURRENT=1
HINDSIGHT_API_RETAIN_LLM_MAX_CONCURRENT=1
HINDSIGHT_API_RETAIN_CHUNK_SIZE=1000
HINDSIGHT_API_RETAIN_MAX_COMPLETION_TOKENS=4096
HINDSIGHT_SEED_DELAY_SECONDS=65

# cascadeflow / Groq routing
CASCADEFLOW_MODE=observe
CASCADEFLOW_LIVE_GROQ=false
CASCADEFLOW_RUN_BUDGET_USD=0.02
CASCADEFLOW_CHEAP_MODEL=qwen/qwen3-32b
CASCADEFLOW_STRONG_MODEL=openai/gpt-oss-120b
