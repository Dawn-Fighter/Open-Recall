{
  "enabled": true,
  "name": "OpenRecall: PBT suite on property-test edit",
  "description": "Runs the full Hypothesis property test suite under the CI profile and the deterministic seed (OPENRECALL_PBT_SEED=20260101) whenever any test under tests/property/ is saved. Reproduces failures deterministically and surfaces falsifying examples verbatim per design § Property Test Configuration.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "incident-memory-agent/tests/property/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd incident-memory-agent && set OPENRECALL_PBT_SEED=20260101 && set HYPOTHESIS_PROFILE=ci && set CASCADEFLOW_LIVE_GROQ=false && set HINDSIGHT_BASE_URL=http://127.0.0.1:9 && python -m pytest tests/property --hypothesis-profile=ci -q --tb=short",
    "timeout": 120
  }
}